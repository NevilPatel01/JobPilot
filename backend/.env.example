# Use localhost when running uvicorn on your machine; use postgres when the backend runs in Docker Compose.
# For Neon: set NEON_CONNECTION_STRING or DATABASE_URL (postgresql:// is auto-converted to +asyncpg).
DATABASE_URL=postgresql+asyncpg://jobpilot:password@localhost:5432/jobpilot
NEON_CONNECTION_STRING=
SECRET_KEY=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@jobpilot.local
SCRAPER_DEBOUNCE_MINUTES=10
MATCH_SCORE_THRESHOLD=40
ALLOWED_ORIGINS=http://localhost:3000
# Set false in production; true for local dev without OAuth
AUTH_DISABLED=true
# Optional: path to tectonic binary (auto-detected from backend/.bin/ when using scripts/dev.sh)
TECTONIC_PATH=
PUBLIC_API_RATE_LIMIT_CREATE=10/minute
PUBLIC_API_RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_STORAGE_URI=memory://

# --- Job Intelligence + Capture (v0.4 — see JOB_INTELLIGENCE_PLAN.md) ---
JOB_INTELLIGENCE_ENABLED=true

# Target provinces for PR-focused collection (AB, BC, ON, SK)
TARGET_PROVINCES=AB,BC,ON,SK

# Adzuna Canada — leave empty to skip source (graceful fallback)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=ca

# JSearch via RapidAPI — leave empty to skip source
RAPIDAPI_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com

# Job Bank Canada — leave empty if not required
JOB_BANK_API_KEY=

# Scraper schedule (America/Toronto) — APScheduler uses these when backend is running
SCRAPER_TIMEZONE=America/Toronto
SCRAPER_MORNING_HOUR=8
SCRAPER_EVENING_HOUR=18
SCRAPER_EVENING_ENABLED=true
SCRAPER_DRY_RUN=false
SCRAPER_MAX_QUERIES_PER_SOURCE=12
SCRAPER_MAX_PAGES=1
SCRAPER_FETCH_DESCRIPTIONS=true

# Fit scoring thresholds (user can override in Settings UI)
FIT_SCORE_LOW_MAX=40
FIT_SCORE_STRETCH_MAX=59
FIT_SCORE_REVIEWED_MAX=74
FIT_SCORE_RECOMMENDED_MAX=84

# Gmail forward import (phase 7) — inbound jobs+token@yourdomain.com
GMAIL_FORWARD_ENABLED=false
GMAIL_INBOUND_DOMAIN=

# Gmail OAuth (phase 9 — later)
GMAIL_OAUTH_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Data retention
JOB_CATALOG_RETENTION_DAYS=180
INBOX_AUTO_ARCHIVE_DAYS=45
RAW_PAYLOAD_RETENTION_DAYS=45

# Follow-up reminders (business days)
FOLLOWUP_FIRST_BUSINESS_DAYS=5
FOLLOWUP_SECOND_BUSINESS_DAYS=10

# Production cron (GitHub Actions) — leave empty to disable /api/v1/internal/cron/scrape
CRON_SECRET=
# Set true when using GitHub Actions instead of in-process APScheduler
DISABLE_APSCHEDULER=false
