# Copy to frontend/.env.local on the Linode server — DO NOT COMMIT filled copy.
# cp deploy/linode/env/frontend.env.local.example frontend/.env.local

NEXTAUTH_URL=https://YOUR_SUBDOMAIN.duckdns.org
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
GITHUB_ID=
GITHUB_SECRET=
NEXT_PUBLIC_API_URL=https://YOUR_SUBDOMAIN.duckdns.org
AUTH_DISABLED=false
NEXT_PUBLIC_AUTH_DISABLED=false
NEXT_PUBLIC_HAS_GITHUB=1
