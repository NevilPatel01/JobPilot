# Copy to backend/.env on the Linode server — DO NOT COMMIT filled copy.
# cp deploy/linode/env/backend.env.example backend/.env

# Neon (preferred) — paste from Neon dashboard; sslmode=require recommended
NEON_CONNECTION_STRING=
# Or use DATABASE_URL directly:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db?sslmode=require

SECRET_KEY=generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=https://YOUR_SUBDOMAIN.duckdns.org
AUTH_DISABLED=false
TECTONIC_PATH=/opt/jobpilot/backend/.bin/tectonic

# Optional job source keys (empty = skip source gracefully)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
RAPIDAPI_KEY=
JOB_BANK_API_KEY=

SCRAPER_TIMEZONE=America/Toronto
SCRAPER_MORNING_HOUR=8
SCRAPER_EVENING_HOUR=18
JOB_INTELLIGENCE_ENABLED=true
TARGET_PROVINCES=AB,BC,ON,SK

# GitHub Actions cron — generate: openssl rand -hex 32
CRON_SECRET=
# Set true if scrapers run only via GitHub Actions
DISABLE_APSCHEDULER=false
